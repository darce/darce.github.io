# Google Analytics measurement ID (public, safe to commit)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Analytics providers to enable (comma-separated: altcontext, ga)
NEXT_PUBLIC_ANALYTICS_PROVIDERS=altcontext,ga

# AltContext analytics backend URL
NEXT_PUBLIC_ALTCTX_BACKEND_URL=https://marketing-altcontext.fly.dev

# AltContext ingest API key (optional while single-tenant)
NEXT_PUBLIC_ALTCTX_INGEST_API_KEY=
